# ============================================================
# AI DEBUGGING AGENT - ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- MongoDB Atlas (Free Tier) ---
# Get from: https://cloud.mongodb.com -> Create free cluster -> Connect
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ai-debugger?retryWrites=true&w=majority

# --- Groq API (FREE - No credit card needed) ---
# Get from: https://console.groq.com -> API Keys -> Create
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- GitHub Personal Access Token (FREE) ---
# Get from: GitHub -> Settings -> Developer Settings -> Personal Access Tokens -> Tokens (classic)
# Required scopes: repo (full control)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# --- GitHub Repo to open PRs on ---
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name

# --- Slack Notifications (OPTIONAL) ---
# Get from: https://api.slack.com/apps -> Create App -> Incoming Webhooks -> Add to Workspace
# Copy the Webhook URL (starts with https://hooks.slack.com/services/...)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# --- Sentry Webhook Secret (OPTIONAL) ---
# Get from: Sentry -> Project Settings -> Integrations -> Webhooks -> Secret
# Your Sentry webhook URL will be: https://your-domain.com/api/webhooks/sentry
SENTRY_WEBHOOK_SECRET=your_sentry_secret_here

# --- Auto-Merge Threshold (OPTIONAL) ---
# PRs with confidence >= this % AND passing syntax validation will be auto-merged
# Set to 101 to disable auto-merge entirely
AUTO_MERGE_THRESHOLD=95

# --- Server Config ---
PORT=5000
NODE_ENV=development

# --- App Being Monitored ---
# Path to the log file of the app you want to monitor
WATCH_LOG_PATH=./logs/app.log
# Root path of the source code being monitored
WATCH_SOURCE_PATH=./logs/sample-app
